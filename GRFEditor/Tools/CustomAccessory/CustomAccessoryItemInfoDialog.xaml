<Styles:TkWindow x:Class="GRFEditor.Tools.CustomAccessory.CustomAccessoryItemInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
        Title="Gerar iteminfo" Height="480" Width="820"
        Background="{StaticResource TabItemBackground}" Foreground="{StaticResource TextForeground}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Defina o ItemId de cada visual e escolha a pasta de destino. Serão criados iteminfo.lua e item_db.yml."/>
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Pasta:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Name="_textOutputFolder" Grid.Column="1" Height="22" VerticalAlignment="Center"/>
                <Button Name="_buttonBrowseFolder" Grid.Column="2" Content="..." Width="32" Height="22" Margin="6,0,0,0" Click="_buttonBrowseFolder_Click"/>
            </Grid>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ItemId inicial:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Name="_textInitialItemId" Width="80" Height="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Name="_buttonAutoItemIds" Content="Atribuir ItemIds sequenciais" Width="160" Height="26" Margin="0,0,8,0" Click="_buttonAutoItemIds_Click"/>
                <TextBlock Name="_textStatus" VerticalAlignment="Center" Opacity="0.85" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
        <DataGrid Grid.Row="2" Name="_gridEntries" AutoGenerateColumns="False" CanUserAddRows="False"
                  HeadersVisibility="Column" SelectionMode="Extended" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="✓" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                <DataGridTextColumn Header="Sprite" Binding="{Binding SpritePath}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding DisplayName}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="ViewId" Binding="{Binding ViewId}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="ItemId" Binding="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="Aegis (preview)" Binding="{Binding AegisPreview}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="3" TokeiLibrary:WpfProperties.IsDraggable="True" Height="40" Background="{DynamicResource UIDialogBackground}">
            <DockPanel HorizontalAlignment="Right">
                <Button Name="_buttonGenerate" Content="Gerar arquivos" Width="120" Height="26" Margin="3" Click="_buttonGenerate_Click"/>
                <Button Content="Fechar" Width="100" Height="26" Margin="3" Click="_buttonClose_Click"/>
            </DockPanel>
        </Grid>
    </Grid>
</Styles:TkWindow>
