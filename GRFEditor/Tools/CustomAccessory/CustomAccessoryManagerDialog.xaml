<Styles:TkWindow x:Class="GRFEditor.Tools.CustomAccessory.CustomAccessoryManagerDialog"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"

        xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"

        MinHeight="580" Height="700" Width="1060" MinWidth="920">

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="auto" />

            <RowDefinition Height="auto" />

            <RowDefinition Height="auto" />

            <RowDefinition Height="auto" />

            <RowDefinition />

            <RowDefinition Height="auto" />

            <RowDefinition Height="auto" />

            <RowDefinition Height="auto" />

        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="8 8 8 4">

            <Label Content="Custom accessories manager" FontWeight="Bold" FontSize="16" Margin="0 0 0 4" />

            <TextBlock Name="_textSummary" TextWrapping="Wrap" Margin="0 0 0 4"

                       Text="Escaneie sprites, edite ConstantName / ViewId / DisplayName e grave em accessoryid.lub e accname.lub. O GRF não é salvo automaticamente."/>

            <Rectangle Height="1" Stroke="{DynamicResource SeperatorBrush}" Margin="0 2 0 0" />

        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="8 4 8 4">

            <Button Name="_buttonScanGrf" Content="Scan GRF" Width="100" Height="24" Margin="0 0 6 4" Click="_buttonScanGrf_Click" />

            <Button Name="_buttonScanFolder" Content="Scan folder" Width="100" Height="24" Margin="0 0 6 4" Click="_buttonScanFolder_Click" />

            <Button Name="_buttonBatchImport" Content="Importar lote" Width="110" Height="24" Margin="0 0 6 4" Click="_buttonBatchImport_Click"
                    ToolTip="Pasta com .spr/.act e CSV opcional (SpriteFile, ConstantName, DisplayName, ViewId)." />

            <Button Name="_buttonSuggest" Content="Sugerir selecionados" Width="130" Height="24" Margin="0 0 6 4" Click="_buttonSuggest_Click" IsEnabled="False" />

            <Button Name="_buttonAutoViewIds" Content="ViewIds sequenciais" Width="130" Height="24" Margin="0 0 6 4" Click="_buttonAutoViewIds_Click" IsEnabled="False" />

            <TextBlock Name="_textLubSources" VerticalAlignment="Center" Opacity="0.85" TextWrapping="Wrap" Margin="0 0 0 4" />

        </WrapPanel>

        <Grid Grid.Row="2" Margin="8 4 8 4">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="auto" />

                <ColumnDefinition Width="200" />

                <ColumnDefinition Width="auto" />

                <ColumnDefinition Width="72" />

                <ColumnDefinition Width="auto" />

                <ColumnDefinition />

            </Grid.ColumnDefinitions>

            <Label Content="Status:" VerticalAlignment="Center" Margin="0 0 6 0" />

            <ComboBox Name="_comboStatus" Grid.Column="1" VerticalAlignment="Center" SelectionChanged="_filters_Changed" />

            <Label Content="ID inicial:" Grid.Column="2" VerticalAlignment="Center" Margin="12 0 6 0" />

            <TextBox Name="_textInitialViewId" Grid.Column="3" Height="24" VerticalContentAlignment="Center"

                     ToolTip="Vazio = maior viewId em accessoryid.lub + 1" />

            <Label Content="Search:" Grid.Column="4" VerticalAlignment="Center" Margin="12 0 6 0" />

            <TextBox Name="_textSearch" Grid.Column="5" VerticalAlignment="Center" Height="24"

                     VerticalContentAlignment="Center" TextChanged="_textSearch_TextChanged" />

        </Grid>

        <StackPanel Grid.Row="3" Margin="8 0 8 4">

            <Label Content="Destino ao gravar:" FontWeight="SemiBold" />

            <WrapPanel>

                <RadioButton Name="_radioEditOnly" GroupName="SaveMode" Content="Só arquivos de edição" Margin="0 0 12 0"

                             IsChecked="True" Checked="_saveMode_Changed" />

                <RadioButton Name="_radioGrfInternal" GroupName="SaveMode" Content="Aplicar no GRF (sem salvar container)" Margin="0 0 12 0"

                             Checked="_saveMode_Changed" />

                <RadioButton Name="_radioExternalDisk" GroupName="SaveMode" Content="Cópia em disco externo" Margin="0 0 12 0"

                             Checked="_saveMode_Changed" />

                <RadioButton Name="_radioGrfAndDisk" GroupName="SaveMode" Content="GRF + disco externo"

                             Checked="_saveMode_Changed" />

            </WrapPanel>

        </StackPanel>

        <DataGrid Grid.Row="4" Name="_gridEntries" Margin="8 0 8 0" AutoGenerateColumns="False"

                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"

                  VirtualizingStackPanel.IsVirtualizing="True" EnableRowVirtualization="True">

            <DataGrid.Columns>

                <DataGridCheckBoxColumn Header="✓" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="36" />

                <DataGridTextColumn Header="Sprite" Binding="{Binding SpritePath}" Width="180" IsReadOnly="True" />

                <DataGridTextColumn Header="Act" Binding="{Binding ActPath}" Width="160" IsReadOnly="True" />

                <DataGridTextColumn Header="ConstantName" Binding="{Binding ConstantName, UpdateSourceTrigger=PropertyChanged}" Width="200" />

                <DataGridTextColumn Header="ViewId" Binding="{Binding ViewId, UpdateSourceTrigger=PropertyChanged}" Width="56" />

                <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="120" />

                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="140" IsReadOnly="True" />

                <DataGridTextColumn Header="Issues" Binding="{Binding Issues}" Width="*" IsReadOnly="True" />

            </DataGrid.Columns>

        </DataGrid>

        <WrapPanel Grid.Row="5" Margin="8 6 8 4" HorizontalAlignment="Left">

            <Button Name="_buttonPreviewDiff" Content="Preview diff" Width="110" Height="24" Margin="0 0 6 0"

                    Click="_buttonPreviewDiff_Click" IsEnabled="False" />

            <Button Name="_buttonSaveLua" Content="Gravar Lua" Width="100" Height="24" Margin="0 0 6 0"

                    Click="_buttonSaveLua_Click" IsEnabled="False" />

            <Button Name="_buttonExportImportPreview" Content="Preview import CSV" Width="120" Height="24" Margin="0 0 6 0"

                    Click="_buttonExportImportPreview_Click" IsEnabled="False"

                    ToolTip="Exporta a grade no formato de preview de importação (antes de gravar Lua)." />

            <Button Name="_buttonExportCsv" Content="Export CSV" Width="100" Height="24" Margin="0 0 6 0"

                    Click="_buttonExportCsv_Click" IsEnabled="False" />

            <Button Name="_buttonExportJson" Content="Export JSON" Width="100" Height="24" Margin="0 0 6 0"

                    Click="_buttonExportJson_Click" IsEnabled="False" />

            <Button Name="_buttonCopySelected" Content="Copy selected" Width="110" Height="24" Margin="0 0 6 0"

                    Click="_buttonCopySelected_Click" IsEnabled="False" />

            <Button Name="_buttonCopyAll" Content="Copy all" Width="90" Height="24" Margin="0 0 6 0"

                    Click="_buttonCopyAll_Click" IsEnabled="False" />

        </WrapPanel>

        <Grid Grid.Row="6" TokeiLibrary:WpfProperties.IsDraggable="True" Height="40" Background="{DynamicResource UIDialogBackground}">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="320" />

                <ColumnDefinition />

            </Grid.ColumnDefinitions>

            <Styles:TkProgressBar x:Name="_progressBar" Margin="8 0 0 0" />

            <DockPanel Grid.Column="1" HorizontalAlignment="Right" Margin="0 0 8 0">

                <Button Name="_buttonClose" Content="Close" Width="100" Height="24" Margin="3" Click="_buttonClose_Click" />

            </DockPanel>

        </Grid>

    </Grid>

</Styles:TkWindow>

