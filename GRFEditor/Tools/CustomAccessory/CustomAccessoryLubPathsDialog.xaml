<Styles:TkWindow x:Class="GRFEditor.Tools.CustomAccessory.CustomAccessoryLubPathsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        Title="Arquivos Lua" Height="220" Width="720" SizeToContent="Manual" ResizeMode="NoResize">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="accessoryid.lub e/ou accname.lub não foram encontrados no GRF nem no perfil. Informe os caminhos nos arquivos de edição."/>
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="accessoryid.lub:" VerticalAlignment="Center"/>
            <Styles:PathBrowser Grid.Column="1" Name="_pbAccessoryId" BrowseMode="File" Filter="Lua files|*.lub;*.lua" Margin="4,0,0,0"/>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="accname.lub:" VerticalAlignment="Center"/>
            <Styles:PathBrowser Grid.Column="1" Name="_pbAccname" BrowseMode="File" Filter="Lua files|*.lub;*.lua" Margin="4,0,0,0"/>
        </Grid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="90" Height="26" Margin="4,0,4,0" Click="_buttonOk_Click" IsDefault="True"/>
            <Button Content="Cancelar" Width="90" Height="26" Margin="4,0,0,0" Click="_buttonCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Styles:TkWindow>
