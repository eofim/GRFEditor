<Styles:TkWindow x:Class="GRFEditor.Core.RagnarokValidation.RagnarokValidationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
        xmlns:ListView="clr-namespace:TokeiLibrary.WPF.Styles.ListView;assembly=TokeiLibrary"
        MinHeight="450" Height="520" Width="920" MinWidth="800"
        Loaded="_window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="8 8 8 4">
            <Label Content="Ragnarok client validation" FontWeight="Bold" FontSize="16" Margin="0 0 0 4" />
            <TextBlock Name="_textSummary" Text="Preparing validation..." TextWrapping="Wrap" Margin="0 0 0 4" />
            <Rectangle Height="1" Stroke="{DynamicResource SeperatorBrush}" Margin="0 2 0 0" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="8 4 8 4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Label Content="Severity:" VerticalAlignment="Center" Margin="0 0 6 0" />
            <ComboBox Name="_comboSeverity" Grid.Column="1" VerticalAlignment="Center" SelectionChanged="_filters_Changed" />
            <Label Content="Category:" Grid.Column="2" VerticalAlignment="Center" Margin="12 0 6 0" />
            <ComboBox Name="_comboCategory" Grid.Column="3" VerticalAlignment="Center" SelectionChanged="_filters_Changed" />
            <Label Content="Search:" Grid.Column="4" VerticalAlignment="Center" Margin="12 0 6 0" />
            <TextBox Name="_textSearch" Grid.Column="5" VerticalAlignment="Center" Height="24"
                     VerticalContentAlignment="Center" TextChanged="_textSearch_TextChanged"
                     ToolTip="Filter by relative path, message, or suggested fix" />
        </Grid>
        <ListView Name="_listViewIssues" Grid.Row="2" Margin="8 0 8 0" BorderThickness="0"
                  Foreground="{StaticResource TextForeground}"
                  ListView:ListViewExtensions.IsGridSortable="True"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        <WrapPanel Grid.Row="3" Margin="8 6 8 4" HorizontalAlignment="Left">
            <Button Name="_buttonSelectFixable" Content="Select fixable" Width="100" Height="24" Margin="0 0 6 0" Click="_buttonSelectFixable_Click"
                    ToolTip="Selects junk/system files and path slash fixes (not empty files)." />
            <Button Name="_buttonClearFixSelection" Content="Clear fix" Width="80" Height="24" Margin="0 0 6 0" Click="_buttonClearFixSelection_Click" />
            <Button Name="_buttonApplyFixes" Content="Apply selected fixes" Width="130" Height="24" Margin="0 0 6 0" Click="_buttonApplyFixes_Click" />
            <Button Name="_buttonCopySelected" Content="Copy selected" Width="110" Height="24" Margin="0 0 6 0" Click="_buttonCopySelected_Click" />
            <Button Name="_buttonCopyAll" Content="Copy all" Width="90" Height="24" Margin="0 0 6 0" Click="_buttonCopyAll_Click" />
            <Button Name="_buttonExportCsv" Content="Export CSV" Width="100" Height="24" Margin="0 0 6 0" Click="_buttonExportCsv_Click" />
            <Button Name="_buttonExportJson" Content="Export JSON" Width="100" Height="24" Margin="0 0 6 0" Click="_buttonExportJson_Click" />
        </WrapPanel>
        <Grid Grid.Row="4" TokeiLibrary:WpfProperties.IsDraggable="True" Height="40" Background="{DynamicResource UIDialogBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Styles:TkProgressBar x:Name="_progressBar" Margin="8 0 0 0" />
            <DockPanel Grid.Column="1" HorizontalAlignment="Right" Margin="0 0 8 0">
                <Button Name="_buttonClose" Content="Close" Width="100" Height="24" Margin="3" Click="_buttonClose_Click" />
            </DockPanel>
        </Grid>
    </Grid>
</Styles:TkWindow>
