<Styles:TkWindow x:Class="GRFEditor.Core.ItemInfo.ItemInfoCsvPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        Title="Prévia CSV iteminfo" Height="560" Width="920" MinHeight="420" MinWidth="720">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Revise as linhas antes de carregar na grade. Linhas inválidas não poderão ser aplicadas."
                   TextWrapping="Wrap" Margin="0,0,0,6"/>
        <TextBox Grid.Row="1" Name="_textReport" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" AcceptsReturn="True"/>
        <DataGrid Grid.Row="2" Name="_gridPreview" Margin="0,6,0,6" AutoGenerateColumns="False"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="L" Binding="{Binding LineNumber}" Width="36" IsReadOnly="True"/>
                <DataGridTextColumn Header="ItemId" Binding="{Binding ItemId}" Width="56" IsReadOnly="True"/>
                <DataGridTextColumn Header="Display" Binding="{Binding IdentifiedDisplayName}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Resource" Binding="{Binding IdentifiedResourceName}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="ClassNum" Binding="{Binding ClassNum}" Width="56" IsReadOnly="True"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="72" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Aplicar" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="52"/>
                <DataGridTextColumn Header="Issues" Binding="{Binding IssuesText}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="_buttonSelectValid" Content="Selecionar válidas" Width="120" Height="26" Margin="4,0,4,0" Click="_buttonSelectValid_Click"/>
            <Button Name="_buttonLoad" Content="Carregar na grade" Width="130" Height="26" Margin="4,0,4,0" Click="_buttonLoad_Click" IsDefault="True"/>
            <Button Content="Cancelar" Width="90" Height="26" Margin="4,0,0,0" Click="_buttonCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Styles:TkWindow>
