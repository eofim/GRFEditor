<Styles:TkWindow x:Class="GRFEditor.Core.ItemInfo.ItemInfoDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        Title="Preview iteminfo" Height="520" Width="800" MinHeight="400" MinWidth="640">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Name="_textHint" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1" Name="_textDiff" IsReadOnly="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" AcceptsReturn="True"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="_buttonApply" Content="Aplicar (com backup)" Width="150" Height="26" Margin="4,0,4,0" Click="_buttonApply_Click"/>
            <Button Content="Cancelar" Width="90" Height="26" Margin="4,0,0,0" Click="_buttonCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Styles:TkWindow>
